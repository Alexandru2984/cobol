IDENTIFICATION DIVISION.
PROGRAM-ID. SEED-LEDGER.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT TRANSACTIONS-FILE ASSIGN TO "data/ledger.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS TRANS-ID
        ALTERNATE RECORD KEY IS TRANS-DATE WITH DUPLICATES
        FILE STATUS IS FS-LEDGER.

DATA DIVISION.
FILE SECTION.
FD  TRANSACTIONS-FILE.
01  TRANS-RECORD.
    05  TRANS-ID            PIC X(10).
    05  TRANS-DATE          PIC X(10).
    05  TRANS-CAT           PIC X(15).
    05  TRANS-DESC          PIC X(30).
    05  TRANS-AMOUNT        PIC S9(7)V99.

WORKING-STORAGE SECTION.
01  FS-LEDGER               PIC XX.

PROCEDURE DIVISION.
    DISPLAY "Re-seeding with alternate keys...".
    OPEN OUTPUT TRANSACTIONS-FILE.
    
    MOVE "0000000001" TO TRANS-ID.
    MOVE "2026-04-10" TO TRANS-DATE.
    MOVE "Venituri"   TO TRANS-CAT.
    MOVE "Salariu Martie" TO TRANS-DESC.
    MOVE 5500.00 TO TRANS-AMOUNT.
    WRITE TRANS-RECORD.

    MOVE "0000000002" TO TRANS-ID.
    MOVE "2026-04-15" TO TRANS-DATE.
    MOVE "Locuinta"   TO TRANS-CAT.
    MOVE "Chirie" TO TRANS-DESC.
    MOVE -1200.00 TO TRANS-AMOUNT.
    WRITE TRANS-RECORD.

    MOVE "0000000003" TO TRANS-ID.
    MOVE "2026-04-12" TO TRANS-DATE.
    MOVE "Utilitati"  TO TRANS-CAT.
    MOVE "Internet" TO TRANS-DESC.
    MOVE -55.00 TO TRANS-AMOUNT.
    WRITE TRANS-RECORD.

    CLOSE TRANSACTIONS-FILE.
    STOP RUN.
